# Copy this file to .env (local dev) and fill in real values.
# .env is gitignored — never commit real secrets.

# --- Database (Postgres) ---
# Local dev: point at any Postgres instance you have (Neon free tier works well: https://neon.tech)
# On Vercel: add a Postgres store from the Storage tab and this is injected automatically.
DATABASE_URL="postgresql://user:password@host:5432/finflow?sslmode=require"

# --- Contract deployment (Hardhat only — never used by the Next.js app at runtime) ---
# Private key of the wallet that owns FinFlowTreasury (0x73cc6BD174543bE6F2Fb40DA7C3C041ceB8c0b1d).
# Used only by `npm run contracts:deploy` to deploy Escrow.sol and BatchPayout.sol.
# Fund this wallet with free testnet USDC first: https://faucet.circle.com
# DO NOT paste this key in chat/screenshots. Edit this value directly in your local .env file.
DEPLOYER_PRIVATE_KEY="0xyourprivatekeyhere"

# --- Public contract addresses (read by the frontend, safe to expose) ---
NEXT_PUBLIC_TREASURY_ADDRESS="0x41BF49FD0606e525b73866BF54e063De5556F4bF"
NEXT_PUBLIC_ESCROW_ADDRESS=""
NEXT_PUBLIC_BATCHPAYOUT_ADDRESS=""

# --- Optional: WalletConnect (get a free projectId at https://cloud.walletconnect.com) ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# --- Cron auth (Vercel Cron sends this header; set any random string) ---
CRON_SECRET="change-me"
